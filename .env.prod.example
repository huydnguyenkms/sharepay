# Copy this file to .env (next to docker-compose.prod.yml) and fill in real values.
# docker compose reads .env automatically. NEVER commit the real .env.

# --- Database ---
DB_NAME=sharepay
DB_USER=sharepay
# Use a strong password. Generate one with: openssl rand -base64 24
DB_PASSWORD=change-me-strong-db-password

# --- Auth ---
# HS256 signing key. MUST be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters-long
# Token lifetime in minutes (default 1440 = 24h)
JWT_EXPIRATION_MINUTES=1440

# --- CORS ---
# Public origin(s) the browser loads the app from. The backend is behind nginx and still
# applies CORS, so this MUST match your real domain or registration/login return 403.
# Multiple origins: comma-separated, e.g. "https://sharepay.pro,https://www.sharepay.pro".
CORS_ALLOWED_ORIGINS=https://sharepay.pro

# --- HTTPS (only used by docker-compose.https.yml) ---
# Your domain(s). For multiple, separate with a space, e.g. "example.com www.example.com".
# The A record(s) must already point to this server's Elastic IP.
DOMAIN=example.com www.example.com
# Email for Let's Encrypt certificate expiry notices.
ACME_EMAIL=you@example.com
